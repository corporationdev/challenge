{
  "name": "challenge",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "convex": "^1.33.1",
      "better-auth": "~1.6.9",
      "@convex-dev/better-auth": "^0.12.2",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3",
      "alchemy": "^0.91.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F @challenge/backend dev",
    "dev:setup": "turbo -F @challenge/backend dev:setup",
    "deploy": "turbo -F @challenge/infra deploy",
    "destroy": "turbo -F @challenge/infra destroy"
  },
  "dependencies": {
    "@challenge/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@challenge/config": "workspace:*",
    "@cloudflare/workers-types": "^4.20251213.0",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.11"
}
